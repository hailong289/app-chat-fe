API_URL=http://localhost:5000/api

# URL frontend — dùng cho Tauri (devUrl / window url) khi chạy build:tauri*
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Trang /download — link tải bản cài (CI deploy gán từ GitHub Releases latest)
# NEXT_PUBLIC_DESKTOP_DOWNLOAD_WINDOWS=https://github.com/<owner>/<repo>/releases/latest/download/EduChat-Windows.msi
# NEXT_PUBLIC_DESKTOP_DOWNLOAD_MACOS=https://github.com/<owner>/<repo>/releases/latest/download/EduChat-macOS.dmg
# NEXT_PUBLIC_DESKTOP_DOWNLOAD_LINUX=https://github.com/<owner>/<repo>/releases/latest/download/EduChat-Linux.deb
# NEXT_PUBLIC_ANDROID_STORE_URL=https://play.google.com/store/apps/details?id=...
# NEXT_PUBLIC_IOS_STORE_URL=https://apps.apple.com/app/id...

# Firebase Configuration - Client-side accessible environment variables
# These must be prefixed with NEXT_PUBLIC_ to be available in the browser
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_firebase_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your_vapid_key
NEXT_PUBLIC_FIREBASE_VAPID_KEY=your_firebase_vapid_key_here