{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "app-chat-fe",
  "version": "0.1.0",
  "identifier": "com.appchat.desktop",
  "build": {
    "beforeDevCommand": "cd ../ && npm run dev",
    "frontendDist": "dummy_dist",
    "devUrl": "http://localhost:3000"
  },
  "app": {
    "windows": [
      {
        "title": "app-chat-fe",
        "width": 800,
        "height": 600,
        "resizable": true,
        "fullscreen": false,
        "url": "http://localhost:3000"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "webviewInstallMode": {
        "type": "downloadBootstrapper",
        "silent": true
      }
    }
  }
}
